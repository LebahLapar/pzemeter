# ============================================================
# Template environment. Salin jadi .env lalu isi nilai asli.
#   cp .env.example .env
# JANGAN commit file .env (sudah masuk .gitignore)
# ============================================================

# ---------- Server ----------
PORT=3000
DASHBOARD_URL=http://localhost:3000

# Lingkungan: development (default, http localhost) atau production (di belakang HTTPS)
NODE_ENV=development

# ---------- Auth / Session ----------
# Secret untuk menandatangani cookie sesi. WAJIB diisi string acak yang kuat & panjang.
# Generate contoh: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=ganti-dengan-string-acak-panjang-yang-kuat
# Kredensial admin awal untuk seeding (hanya dipakai saat koleksi user kosong)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ganti-password-admin-yang-kuat

# ---------- MongoDB ----------
# Untuk docker compose dipakai mongodb://mongo:27017/pzemeter (di-override compose)
MONGO_URI=mongodb://localhost:27017/pzemeter

# ---------- MQTT ----------
MQTT_URL=mqtt://broker.avisha.id:1883
MQTT_USER=barka
MQTT_PASS=
# Broker membatasi user pada topic "username/#". Topic harus diawali "barka/".
MQTT_TOPIC_DATA=barka/monitor

# ---------- Telegram ----------
# Dapatkan token dari @BotFather, chat id dari @userinfobot
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
# Interval minimum laporan otomatis (ms). 60000 = 1 menit
TG_REPORT_INTERVAL_MS=60000

# ---------- Tarif PLN ----------
TARIFF_PER_KWH=1444.70
